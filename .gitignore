# Python
__pycache__/
*.pyc
*.pyo
.env
.venv/
*.egg-info/

# Outputs (regenerable) — everything under outputs/ is reproducible from the
# pipeline; never commit. Only keep .gitkeep markers for required dirs.
outputs/
!outputs/**/.gitkeep

# Generated assemblies anywhere — large STEP / STL / 3MF / GCODE binaries
*.stl
*.f3d
*.3dm
*.3mf
*.gcode
*.bgcode

# Cache directories
.cache/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Workspace scratch (test data + base64 image dumps from agent runs)
workspace/
!workspace/**/.gitkeep

# Workspace
workspace/scratchpad/
!workspace/**/.gitkeep
data/memory/raw_log*.jsonl

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Private
.millforge/
frontend/node_modules/
frontend/dist/

.vercel
.coverage
diy-fab-session.sqlite

# Local audit + tooling
.audit/
.tools/
candidate.step

# Rhino plug-in build artifacts — the .rhp + deps are auto-installed
# into %APPDATA%\McNeel\Rhinoceros\packages\8.0\AriaPanel\ by the
# csproj's SyncToRhinoPackages target on every Release build. The
# bin/Release/ tree is regenerable; never commit.
cad-plugins/rhino/AriaPanel/bin/
cad-plugins/rhino/AriaPanel/obj/
